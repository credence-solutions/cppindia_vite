// For format details, see https://aka.ms/devcontainer.json. For config options, see the
// README at: https://github.com/devcontainers/templates/tree/main/src/docker-existing-docker-compose
{
  "name": "CppIndia Website",
  "dockerComposeFile": ["../docker/docker-compose.yml"],
  "service": "app",
  "workspaceFolder": "/workspace",
  "forwardPorts": [5173],
  // Mount Claude Code OAuth credentials from host for persistent authentication
  "mounts": [
    {
      "source": "${localEnv:HOME}/.claude-devcontainer/",
      "target": "/home/credence/.claude",
      "type": "bind"
    },
    {
      "source": "${localEnv:HOME}/.claude-devcontainer.json/",
      "target": "/home/credence/.claude.json",
      "type": "bind"
    }
  ],
  "customizations": {
    "vscode": {
      "extensions": [
        "Vue.volar",
        "dbaeumer.vscode-eslint",
        "esbenp.prettier-vscode",
        "Anthropic.claude-code"
      ]
    }
  },
  "remoteUser": "credence"
}
